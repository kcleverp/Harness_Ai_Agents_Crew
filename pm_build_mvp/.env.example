# =============================================
# CONNECTION (required)
# =============================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================
# ROLE-BASED MODELS (all 7 required)
# Confirm exact slugs at https://openrouter.ai/models
# =============================================

# Phase 1 — Idea generation/revision (low-cost)
OPENROUTER_MODEL_IDEA=google/gemini-2.5-flash

# Phase 1 — Idea critique (low-cost)
OPENROUTER_MODEL_IDEA_CRITIC=openai/gpt-4o-mini

# Phase 2 — Synthesis/structuring (low-cost)
OPENROUTER_MODEL_SYNTHESIS=openai/gpt-4o-mini

# Phase 3 — Decision/architecture (high-quality)
OPENROUTER_MODEL_DECISION=anthropic/claude-opus-4-5

# Phase 4 — Creative production (high-quality)
OPENROUTER_MODEL_CREATIVE=anthropic/claude-sonnet-4-5

# Phase 5 — Technical JSON generation (low-cost)
OPENROUTER_MODEL_TECH_GEN=google/gemini-2.5-flash

# Phase 5 — Technical review/correction (low-cost)
OPENROUTER_MODEL_TECH_REVIEW=openai/gpt-4o-mini

# =============================================
# TRANSLATOR (post-process Korean — optional)
# Used by harness/translator_runner.py only.
# If unset, falls back to OPENROUTER_MODEL_IDEA.
# =============================================
OPENROUTER_TRANSLATOR_MODEL=google/gemini-2.5-flash

# =============================================
# v4 ROLES (all optional — warn if unset, phase skipped)
# Confirm exact slugs at https://openrouter.ai/models
# =============================================

# Phase C — Strategic QA: Founder Preservation
OPENROUTER_MODEL_STRATEGIC_QA=anthropic/claude-sonnet-4-5

# Phase C — Strategic QA: Market Viability (Investor)
OPENROUTER_MODEL_INVESTOR_QA=anthropic/claude-opus-4-5

# Phase C — Decision Council roles
OPENROUTER_MODEL_COUNCIL_STRATEGIC=anthropic/claude-opus-4-5
OPENROUTER_MODEL_COUNCIL_EXECUTION=openai/gpt-4o
OPENROUTER_MODEL_COUNCIL_SIMPLE=openai/gpt-4o-mini

# Phase D — Validation Strategy Engine
OPENROUTER_MODEL_VALIDATION=anthropic/claude-sonnet-4-5

# Phase D — Failure Scenario Generator
OPENROUTER_MODEL_FAILURE_SCENARIO=google/gemini-2.5-flash

# Phase D — Production Consistency Guardrail
OPENROUTER_MODEL_CONSISTENCY=openai/gpt-4o-mini

# Escalation routing (failure-type based)
OPENROUTER_MODEL_ESCALATION_LOGIC=openai/gpt-4o
OPENROUTER_MODEL_ESCALATION_OPS=google/gemini-2.5-pro
OPENROUTER_MODEL_ESCALATION_SPEC=anthropic/claude-sonnet-4-5

# =============================================
# DEPRECATED — kept for patch_engine.py only
# New phase code uses role-specific vars above.
# =============================================
# OPENROUTER_MODEL=

# =============================================
# FALLBACK: OpenAI-compatible (if OPENROUTER_* not set)
# =============================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=
