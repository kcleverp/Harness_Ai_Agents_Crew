# =============================================
# PRIMARY: OpenRouter (recommended)
# llm_factory.py reads these first
# =============================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=

# =============================================
# TRANSLATOR (post-process Korean translation)
# Used by harness/translator_runner.py only.
# Confirm the exact slug at https://openrouter.ai/models
# e.g. google/gemini-flash-1.5  or  google/gemini-2.0-flash-001
# If unset, falls back to OPENROUTER_MODEL above.
# =============================================
OPENROUTER_TRANSLATOR_MODEL=

# =============================================
# FALLBACK: OpenAI-compatible (used if OPENROUTER_* not set)
# llm_factory.py falls back to these
# =============================================
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL_NAME=
