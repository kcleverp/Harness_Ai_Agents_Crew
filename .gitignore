# =============================================================
# SECRETS & ENV
# =============================================================
.env
.env.local
.env.*.local
# .env.example is intentionally tracked (template, no real keys)

# =============================================================
# PYTHON
# =============================================================
__pycache__/
*.py[cod]
*.so

# virtual environments
venv/
.venv/
env/
ENV/

# packaging / build artifacts
*.egg-info/
dist/
build/
*.egg
MANIFEST

# type checking / testing
.mypy_cache/
.dmypy.json
.pytest_cache/
.coverage
htmlcov/

# =============================================================
# WORKSPACE RUNTIME OUTPUTS
# LLM 실행 결과물 — 실행마다 재생성되므로 추적 불필요
# =============================================================

# current/ 내 모든 생성 파일 (founder_summary, spec, handoff 등)
pm_build_mvp/workspace/current/**
# current/ 루트 .gitkeep 보존
!pm_build_mvp/workspace/current/.gitkeep
# 디렉토리는 다시 허용 (하위 .gitkeep 예외를 위해 필요)
!pm_build_mvp/workspace/current/**/
# 폴더 구조용 .gitkeep 만 보존
!pm_build_mvp/workspace/current/**/.gitkeep

# archive/ 하위 스냅샷 폴더 (실행마다 생성됨)
pm_build_mvp/workspace/archive/*
!pm_build_mvp/workspace/archive/.gitkeep

# legacy_run 전체 제외
pm_build_mvp/workspace/legacy_run/

# 로컬 입력·커널 (샘플: pm_build_mvp/templates/raw_ideas.sample.md)
pm_build_mvp/workspace/raw_ideas.md
pm_build_mvp/workspace/founder_kernel.json
# =============================================================
# LOGS
# 실행 로그는 로컬 전용 — .gitkeep 으로 디렉토리만 추적
# (projections/, views/ 등 하위 폴더 포함 전부 무시)
# =============================================================
pm_build_mvp/logs/**
!pm_build_mvp/logs/.gitkeep
!pm_build_mvp/logs/**/
!pm_build_mvp/logs/**/.gitkeep

# =============================================================
# OS ARTIFACTS
# =============================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# =============================================================
# IDE / EDITOR
# =============================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================
# CURSOR
# 개인 설정은 추적하지 않음 (팀 공유 규칙은 .cursor/rules/ 에서 별도 관리)
# =============================================================
.cursor/mcp.json

### 이미 placeholder로 커밋되었고 크루 운영시마다 변경되는 idea와 kernel
pm_build_mvp/workspace/raw_ideas.md
pm_build_mvp/workspace/founder_kernel.json

